{
  "name": "hugo-balestrandfjordangling",
  "version": "1.0.0",
  "description": "Website using Hugo",
  "main": "index.js",
  "scripts": {
    "install": "cd themes/balevikit-tailwindcss-hugo-theme && npm install",
    "seo:check": "hugo --minify --printPathWarnings --printUnusedTemplates --templateMetricsHints",
    "backstop:reference": "backstop reference --configPath=backstop.json",
    "backstop:test": "backstop test --configPath=backstop.json",
    "backstop:approve": "backstop approve --configPath=backstop.json",
    "backstop:open": "backstop openReport --configPath=backstop.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreasbalevik/hugo-balestrandfjordangling.com.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/andreasbalevik/hugo-balestrandfjordangling.com/issues"
  },
  "homepage": "https://github.com/andreasbalevik/hugo-balestrandfjordangling.com#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "backstopjs": "^6.3.25",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19"
  }
}
